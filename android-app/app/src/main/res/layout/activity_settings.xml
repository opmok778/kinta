<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kinta_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/kinta_primary"
            android:elevation="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/server_settings_help"
                android:textColor="@color/kinta_text"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/server_settings_label"
                android:textColor="@color/kinta_text"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/homeUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:autofillHints="url"
                android:hint="@string/server_settings_hint"
                android:inputType="textUri"
                android:maxLines="2"
                android:minHeight="56dp"
                android:padding="14dp"
                android:textColor="@color/kinta_text"
                android:textColorHint="#735E6E63" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="4dp"
                android:text="@string/server_settings_examples"
                android:textColor="@color/kinta_text_secondary" />

            <Button
                android:id="@+id/saveServerUrlButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/kinta_primary"
                android:text="@string/save_server_url"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/openAppButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/kinta_accent"
                android:text="@string/open_kinta"
                android:textColor="@color/kinta_text" />
        </LinearLayout>
    </LinearLayout>

</ScrollView>
